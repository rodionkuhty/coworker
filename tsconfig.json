{
  "compilerOptions": {
    "jsx": "react",
    "moduleResolution": "nodenext",
    "target": "ES2022",
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@main/*": ["src/*"],
      "@renderer/*": ["src/renderer/*"],
    }
  },
  "references": [
    { "path": "./src/app/tsconfig.node.json"},
    { "path": "./src/renderer/tsconfig.renderer.json"}
  ]
}